# Production loopback backend for Caddy (set.tido.site -> 127.0.0.1:7778)
# Copy to deploy/setgame.env (gitignored). Do not commit secrets.
PORT=7778
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=1
RAILS_LOG_LEVEL=info
# Required in production after config/master.key was removed from git:
# RAILS_MASTER_KEY=your_32_byte_hex_master_key
