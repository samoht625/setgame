{
  "name": "Set Game",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "install": "./script/bootstrap-dev.sh",
  "ports": [
    {
      "name": "Rails",
      "port": 3000
    }
  ],
  "terminals": [
    {
      "name": "dev",
      "command": "bin/dev",
      "description": "Rails on port 3000 with JS and CSS watchers (Foreman / Procfile.dev)"
    }
  ]
}
